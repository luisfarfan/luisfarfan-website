---
import '../styles/global.css';
import { SITE } from '../config/site';

import { ViewTransitions } from 'astro:transitions';

interface HreflangAlternate {
  hreflang: string;
  href: string;
}

interface Props {
  lang: string;
  title: string;
  description: string;
  keywords: string;
  canonicalUrl: string;
  openGraphLocale: string;
  personName: string;
  personEmail: string;
  personJobTitle: string;
  personDescription: string;
  personSameAs: string[];
  hreflangAlternates: HreflangAlternate[];
  extraSchema?: any;
  articleMeta?: {
    publishedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const {
  lang,
  title,
  description,
  keywords,
  canonicalUrl,
  openGraphLocale,
  personName,
  personEmail,
  personJobTitle,
  personDescription,
  personSameAs,
  hreflangAlternates,
  extraSchema,
  articleMeta,
} = Astro.props;

const ogImageUrl = new URL(SITE.ogImage, SITE.url).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: personName,
  url: canonicalUrl,
  email: personEmail,
  jobTitle: personJobTitle,
  description: personDescription,
  sameAs: personSameAs,
  knowsAbout: [
    'Full Stack Development',
    'Backend Development',
    'Frontend Development',
    'DevOps',
    'Serverless Architecture',
    'Artificial Intelligence',
    'Machine Learning',
    'RAG',
    'LLM',
    'TypeScript',
    'React',
    'Node.js',
    'AWS',
    'Docker',
    'Kubernetes',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Lima',
    addressCountry: 'PE',
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />

    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const theme = getTheme();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={personName} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    {hreflangAlternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={openGraphLocale} />
    <meta property="og:site_name" content={personName} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta?.author && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.tags?.map(tag => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:creator" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="robots" content="index, follow, max-image-preview:large" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {extraSchema && <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <ViewTransitions />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
  </head>

  <body
    data-person-name={personName}
    data-person-email={personEmail}
    data-person-job={personJobTitle}
  >
    <div id="cursor" transition:persist></div>
    <div id="cursor-ring" transition:persist></div>

    <slot />

    <script is:inline>
      const init = () => {
        const cursor = document.getElementById('cursor');
        const ring = document.getElementById('cursor-ring');
        
        const isTouch = window.matchMedia('(pointer: coarse)').matches;
        if (isTouch) {
          if (cursor) cursor.style.display = 'none';
          if (ring) ring.style.display = 'none';
          return;
        }

        let mx = 0, my = 0; 
        let rx = 0, ry = 0; 
        let initialized = false;

        const updatePosition = () => {
          if (cursor) {
            cursor.style.transform = `translate3d(${mx}px, ${my}px, 0) translate(-50%, -50%)`;
          }
          rx += (mx - rx) * 0.15;
          ry += (my - ry) * 0.15;
          if (ring) {
            ring.style.transform = `translate3d(${rx}px, ${ry}px, 0) translate(-50%, -50%)`;
          }
          requestAnimationFrame(updatePosition);
        };

        const onMouseMove = (e) => {
          mx = e.clientX;
          my = e.clientY;
          if (!initialized) {
            initialized = true;
            rx = mx;
            ry = my;
            if (cursor) cursor.style.opacity = '1';
            if (ring) ring.style.opacity = '1';
            updatePosition();
          }
        };

        const onMouseDown = () => { if (ring) ring.style.scale = '0.8'; };
        const onMouseUp = () => { if (ring) ring.style.scale = '1'; };

        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mousedown', onMouseDown);
        document.addEventListener('mouseup', onMouseUp);

        // Hover effect for links
        const handleHover = (e) => {
          const target = e.target;
          if (target.closest('[data-hover]') || target.tagName === 'A' || target.tagName === 'BUTTON') {
            if (ring) {
              ring.style.width = '60px';
              ring.style.height = '60px';
              ring.style.borderColor = 'var(--accent)';
              ring.style.backgroundColor = 'color-mix(in srgb, var(--accent) 5%, transparent)';
            }
          } else {
            if (ring) {
              ring.style.width = '32px';
              ring.style.height = '32px';
              ring.style.borderColor = 'var(--border)';
              ring.style.backgroundColor = 'transparent';
            }
          }
        };

        document.addEventListener('mouseover', handleHover);

        // Observer for animations
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-fade-up');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 },
        );

        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
      };

      document.addEventListener('astro:page-load', init);
    </script>

    <script is:inline>
      const showEasterEgg = () => {
        const _name = document.body.getAttribute('data-person-name') ?? '';
        const _email = document.body.getAttribute('data-person-email') ?? '';
        const _job = document.body.getAttribute('data-person-job') ?? '';
        const g = '#00c896';
        const d = '#888';
        const p = '#0a0a0a';
        console.log('%c> ' + _name.toLowerCase().replace(' ', '.'), `color:${g};font-family:"JetBrains Mono",monospace;font-size:18px;font-weight:700;`);
        console.log('%c  ' + _job, `color:${d};font-family:"JetBrains Mono",monospace;font-size:11px;`);
        console.log('%c  ─────────────────────────────────────────', `color:${d};font-family:monospace;font-size:10px;`);
        console.log('%c  So you opened DevTools. I respect that.', `color:${d};font-family:"JetBrains Mono",monospace;font-size:11px;`);
        console.log('%c  → ' + _email, `color:${g};font-family:"JetBrains Mono",monospace;font-size:11px;`);
      };

      document.addEventListener('astro:page-load', showEasterEgg);
    </script>
  </body>
</html>
