---
import HeroHeadlinePretext from '../HeroHeadlinePretext.tsx';
import HeroContextWidgets from '../HeroContextWidgets.tsx';
import type { HomeCopy } from '../../i18n/home';

interface Props {
  copy: Pick<HomeCopy, 'ME' | 'hero' | 'sectionIds' | 'srOnly' | 'personJobTitle' | 'about'>;
}

const { ME, hero, sectionIds, srOnly, personJobTitle, about } = Astro.props.copy;

// Find availability and location from about values
const availability = about.values.find(v => v.label.toLowerCase().includes('disponibilidad') || v.label.toLowerCase().includes('availability'))?.value || '';
const location = ME.location;
---

<section
  class="relative border-b border-[var(--border)] overflow-hidden bg-grid-pattern"
  style="min-height:92vh;"
>
  <!-- Ambient Glow -->
  <div class="absolute inset-0 pointer-events-none opacity-40 dark:opacity-20" 
       style="background: radial-gradient(circle at 30% 30%, var(--accent) 0%, transparent 40%); filter: blur(120px);">
  </div>

  <div class="relative mx-auto max-w-[1400px] px-4 py-10 sm:px-8 sm:py-12 md:px-10 md:py-14 flex flex-col justify-between" style="min-height:92vh;">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start mt-10">
      
      {/* Main Content Area (8 cols) */}
      <div class="lg:col-span-8">
        <p
          class="animate-fade-up delay-100 font-mono text-[0.6875rem] text-accent tracking-[0.15em] uppercase mb-6 flex items-center gap-3"
        >
          <span class="w-8 h-[1px] bg-accent/30"></span>
          // {personJobTitle} · {ME.years} {hero.kickerSuffix}
        </p>

        <h1 class="sr-only">
          {ME.name} — {personJobTitle}
        </h1>

        <p class="sr-only">{srOnly.heroCanvas}</p>
        <div class="animate-fade-up delay-200 mt-2 w-full">
          <HeroHeadlinePretext client:load name={ME.name} />
        </div>

        <div class="mt-12 flex flex-col md:flex-row md:items-start gap-12">
          <div class="flex-1">
            <p
              class="animate-fade-up delay-300 font-mono text-[0.8125rem] text-muted leading-[1.85] max-w-[28rem]"
              set:html={hero.subtitle}
            />
            
            <p class="animate-fade-up delay-400 mt-6 font-display text-[0.9375rem] text-ink/80 italic leading-relaxed max-w-[25rem] border-l-2 border-accent/20 pl-4">
              "{hero.philosophy}"
            </p>
          </div>

          <div class="animate-fade-up delay-500 flex flex-col gap-5 pt-2">
            <a
              href={`#${sectionIds.projects}`}
              class="bg-ink text-paper px-8 py-4 font-mono text-[0.8125rem] rounded-[0.125rem] no-underline tracking-[0.05em] transition-all duration-200 inline-block hover:bg-accent hover:text-ink cursor-none shadow-lg text-center"
              data-hover
            >
              {hero.ctaProjects}
            </a>
            <a
              href={ME.cvUrl}
              class="font-mono text-[0.75rem] text-muted tracking-[0.05em] no-underline border-b border-muted/30 pb-0.5 hover:text-ink hover:border-ink transition-colors text-center"
              data-hover
            >
              {hero.ctaCv}
            </a>
          </div>
        </div>
      </div>

      {/* Side Bento Area (4 cols) */}
      <div class="lg:col-span-4 animate-fade-up delay-450">
        <HeroContextWidgets 
          client:load 
          availability={availability}
          archTitle={hero.archTitle}
          archItems={hero.archItems}
          aiTitle={hero.aiTitle}
          focus={hero.focus}
        />
      </div>
    </div>

    {/* Bottom Stats Grid */}
    <div class="animate-fade-up delay-600 grid grid-cols-1 sm:grid-cols-3 border-t border-l border-[var(--border)] mb-10 sm:mb-0">
      {[
        { num: ME.years, label: hero.statsYears },
        { num: `${ME.projectCount}+`, label: hero.statsProjects },
        { num: ME.aiProjects, label: hero.statsAi },
      ].map((s) => (
        <div class="p-6 sm:p-8 border-r border-b border-[var(--border)] bg-paper/20 backdrop-blur-[2px] hover:bg-paper/40 transition-colors">
          <div class="font-display text-[2.75rem] font-extrabold text-ink leading-none">
            {s.num}
          </div>
          <div
            class="font-mono text-[0.625rem] text-muted tracking-[0.12em] uppercase mt-2.5"
          >
            {s.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
