---
import PretextHero from '../PretextHero.tsx';
import type { HomeCopy } from '../../i18n/home';

interface Props {
  copy: Pick<HomeCopy, 'ME' | 'hero' | 'sectionIds' | 'srOnly'>;
}

const { ME, hero, sectionIds, srOnly } = Astro.props.copy;
---

<section
  class="hero-grid"
  style="display:grid; grid-template-columns:1fr 1fr; min-height:88vh; border-bottom:1px solid var(--border);"
>
  <div
    style="padding:60px 40px; display:flex; flex-direction:column; justify-content:space-between; border-right:1px solid var(--border);"
  >
    <div>
      <p
        class="animate-fade-up delay-100"
        style="font-family:'DM Mono',monospace; font-size:11px; color:var(--accent); letter-spacing:.15em; text-transform:uppercase; margin-bottom:24px;"
      >
        // Full Stack · DevOps · AI · {ME.years} {hero.kickerSuffix}
      </p>

      <h1
        class="animate-fade-up delay-200"
        style="font-family:'Syne',sans-serif; font-size:clamp(52px,7vw,84px); font-weight:800; line-height:.95; letter-spacing:-.03em; color:var(--ink);"
      >
        SENIOR<br />
        <span style="color:transparent; -webkit-text-stroke:1.5px var(--ink);">FULL</span><br />
        <span style="color:var(--accent);">STACK</span>
      </h1>

      <p
        class="animate-fade-up delay-400"
        style="font-family:'DM Mono',monospace; font-size:13px; color:var(--muted); line-height:1.85; max-width:400px; margin-top:28px;"
        set:html={hero.subtitle}
      />
    </div>

    <div>
      <div class="animate-fade-up delay-500" style="display:flex; align-items:center; gap:20px; margin-top:48px;">
        <a
          href={`#${sectionIds.projects}`}
          style="background:var(--ink); color:var(--paper); padding:14px 28px; font-family:'DM Mono',monospace; font-size:13px; border-radius:2px; text-decoration:none; letter-spacing:.05em; transition:all .2s; display:inline-block;"
          onmouseover="this.style.background='var(--accent)'; this.style.color='var(--ink)';"
          onmouseout="this.style.background='var(--ink)'; this.style.color='var(--paper)';"
          data-hover
        >
          {hero.ctaProjects}
        </a>
        <a
          href={ME.cvUrl}
          style="font-family:'DM Mono',monospace; font-size:12px; color:var(--muted); letter-spacing:.05em; text-decoration:none; border-bottom:1px solid var(--muted); padding-bottom:2px;"
          data-hover
        >
          {hero.ctaCv}
        </a>
      </div>

      <div class="animate-fade-up delay-600" style="display:flex; margin-top:48px; border-top:1px solid var(--border);">
        {[
          { num: ME.years, label: hero.statsYears },
          { num: `${ME.projectCount}+`, label: hero.statsProjects },
          { num: ME.aiProjects, label: hero.statsAi },
        ].map((s, i) => (
          <div
            style={`padding:20px ${i === 0 ? '28px 20px 20px 0' : '20px'}; ${i < 2 ? 'border-right:1px solid var(--border);' : ''} flex:1;`}
          >
            <div style="font-family:'Syne',sans-serif; font-size:38px; font-weight:800; color:var(--ink); line-height:1;">
              {s.num}
            </div>
            <div
              style="font-family:'DM Mono',monospace; font-size:10px; color:var(--muted); letter-spacing:.12em; text-transform:uppercase; margin-top:6px;"
            >
              {s.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div style="position:relative; overflow:hidden; min-height:500px;">
    <p class="sr-only">{srOnly.heroCanvas}</p>
    <div
      style="position:absolute; top:18px; right:18px; font-family:'DM Mono',monospace; font-size:10px; color:rgba(10,10,10,0.3); letter-spacing:.1em; z-index:2;"
      aria-hidden="true"
    >
      // @chenglou/pretext layout live
    </div>
    <PretextHero client:visible />
  </div>
</section>
