---
import type { HomeCopy } from '../../i18n/home';
import TechConsole from './TechConsole';

interface Props {
  sectionId: string;
  stack: HomeCopy['stack'];
  columns: HomeCopy['STACK'];
}

const { sectionId, stack, columns } = Astro.props;
---

<section id={sectionId} class="py-14 sm:py-24 px-6 sm:px-10 border-b border-ink/10">

  <div data-animate class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
    <div class="flex items-baseline gap-5">
      <span class="font-mono text-[0.6875rem] text-muted tracking-[0.12em]">
        {stack.sectionNum}
      </span>
      <h2 class="font-display text-[2.5rem] sm:text-[3.5rem] font-bold tracking-tight text-ink">
        {stack.title}
      </h2>
    </div>

    <div class="max-w-xs">
      <p class="font-mono text-[0.75rem] text-muted leading-relaxed uppercase tracking-wider">
        // {stack.techLine1} <br />
        // {columns.reduce((acc, col) => acc + col.items.length, 0)} {stack.techLine2Suffix}
      </p>
    </div>
  </div>

  <div data-animate>
    <TechConsole client:visible columns={columns} />
  </div>

  <div class="mt-12 flex items-center gap-4">
    <div class="w-12 h-[1px] bg-accent/20"></div>
    <p class="font-mono text-[0.625rem] text-muted tracking-widest uppercase">
      {stack.hint}
    </p>
  </div>
</section>
