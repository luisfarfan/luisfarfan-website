---
import Terminal from '../Terminal.tsx';
import type { HomeCopy } from '../../i18n/home';

interface Props {
  sectionId: string;
  about: HomeCopy['about'];
  bio: string;
}

const { sectionId, about, bio } = Astro.props;
const aboutTitleHtml = about.titleLines.join('<br />');
---

<section
  id={sectionId}
  class="flex flex-col md:grid md:grid-cols-2 border-b border-[var(--border)]"
>
  <div class="p-10 sm:p-14 md:p-[4.375rem_2.5rem] border-b md:border-b-0 md:border-r border-[var(--border)]">
    <div
      class="font-mono text-[0.6875rem] text-muted tracking-[0.12em] uppercase mb-5"
    >
      {about.sectionNum}
    </div>
    <h2
      data-animate
      class="font-display text-[2.5rem] sm:text-[2.875rem] font-extrabold tracking-[-0.03em] leading-[1.05] mb-7"
      set:html={aboutTitleHtml}
    />
    <p class="font-mono text-[0.8125rem] text-muted leading-[1.9] white-space-pre-line">
      {bio}
    </p>

    <div class="grid grid-cols-2 gap-0 mt-10 border-t border-[var(--border)]">
      {about.values.map((item, i) => (
        <div
          class:list={[
            'p-4.5 sm:p-5',
            i % 2 === 0 ? 'border-r border-[var(--border)]' : '',
            i < 2 ? 'border-bottom border-[var(--border)]' : ''
          ]}
          style={i < 2 ? 'border-bottom: 1px solid var(--border);' : ''}
        >
          <div
            class="font-mono text-[0.625rem] text-muted tracking-[0.1em] uppercase mb-1.5"
          >
            {item.label}
          </div>
          <div class="font-mono text-[0.8125rem] text-ink">{item.value}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="p-10 sm:p-14 md:p-10 bg-ink flex items-center min-h-[400px]">
    <div class="w-full">
      <Terminal client:visible />
    </div>
  </div>
</section>
