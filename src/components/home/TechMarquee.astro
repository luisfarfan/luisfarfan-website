---
interface Props {
  items: string[];
}

const { items } = Astro.props;
const loop = [...items, ...items];
---

<div class="border-b border-[var(--border)] py-3.5 overflow-hidden bg-ink" aria-hidden="true">
  <div class="flex animate-[marquee_20s_linear_infinite] whitespace-nowrap">
    {loop.map((item) => (
      <span
        class="font-mono text-[0.75rem] text-paper/55 px-8 tracking-[0.1em] uppercase"
      >
        <span class="text-accent mr-2">▸</span>
        {item}
      </span>
    ))}
  </div>
</div>
