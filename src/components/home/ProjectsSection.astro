---
import type { HomeCopy, ProjectItem } from '../../i18n/home';

interface Props {
  sectionId: string;
  projects: HomeCopy['projects'];
  items: ProjectItem[];
  githubUrl: string;
}

const { sectionId, projects, items, githubUrl } = Astro.props;
---

<section id={sectionId} class="border-b border-[var(--border)]">
  <div class="flex flex-col lg:grid lg:grid-cols-[17.5rem_1fr]">
    <div class="p-6 sm:p-14 lg:p-[3.75rem_2.5rem] border-b lg:border-b-0 lg:border-r border-[var(--border)] flex flex-col justify-between">
      <div>
        <div
          class="font-mono text-[0.6875rem] text-muted tracking-[0.12em] uppercase mb-4"
        >
          {projects.sectionNum}
        </div>
        <div
          class="font-display text-[2.75rem] sm:text-[3.25rem] font-extrabold leading-[0.95] tracking-[-0.03em]"
          set:html={projects.sidebarTitleHtml}
        />
        <p class="font-mono text-[0.75rem] text-muted leading-[1.85] mt-5">
          {projects.sidebarLead}
        </p>
      </div>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 block text-center bg-ink text-paper px-5 py-3.5 font-mono text-[0.8125rem] rounded-[0.125rem] no-underline tracking-[0.05em] transition-all duration-200 hover:bg-accent hover:text-ink cursor-none"
        data-hover
      >
        {projects.sidebarCta}
      </a>
    </div>

    <div class="divide-y divide-[var(--border)]">
      {items.map((p) => (
        <div
          class="grid grid-cols-1 md:grid-cols-[1fr_auto] items-start gap-8 p-5 sm:p-12 transition-colors duration-150 hover:bg-paper/50 group relative overflow-hidden"
        >
          {/* Subtle background glow on hover */}
          <div class="absolute inset-0 bg-accent/2 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />

          <div class="relative z-10">
            <div class="font-mono text-[0.625rem] text-muted group-hover:text-accent tracking-widest mb-3 flex items-center gap-2 transition-colors duration-200">
              <span class="w-1 h-1 rounded-full bg-accent" />
              {p.num}
            </div>
            
            <a 
              href={p.url !== '#' ? p.url : (p.blog || '#')} 
              target={p.url !== '#' ? '_blank' : '_self'}
              rel={p.url !== '#' ? 'noopener noreferrer' : ''} 
              class="inline-flex items-center gap-2 font-display text-[1.75rem] font-bold tracking-tight text-ink hover:text-accent transition-colors mb-3 cursor-none"
              data-hover
            >
              {p.name}
              <span class="text-[1.25rem] opacity-30 group-hover:opacity-100 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">↗</span>
            </a>

            <p class="font-mono text-[0.8125rem] text-muted leading-relaxed max-w-2xl mb-6">
              {p.desc}
            </p>

            <div class="flex flex-wrap items-center gap-6">
              {/* Technical Tags */}
              <div class="flex gap-1.5 flex-wrap">
                {p.tags.map((tag) => (
                  <span
                    class:list={[
                      'font-mono text-[0.625rem] px-2.5 py-1 rounded-[0.125rem] tracking-[0.05em] border transition-colors',
                      p.accentTags.includes(tag) 
                        ? 'border-accent/40 text-accent bg-accent/5' 
                        : 'border-[var(--border)] text-muted'
                    ]}
                  >
                    {tag}
                  </span>
                ))}
              </div>

              {/* Action Links */}
              {(p.github || p.blog) && (
                <div class="flex items-center gap-5 border-l border-ink/10 pl-6">
                  {p.github && (
                    <a 
                      href={p.github} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      class="flex items-center gap-2 font-mono text-[0.6875rem] text-muted hover:text-ink transition-colors cursor-none group/link"
                      data-hover
                    >
                      <svg class="w-3.5 h-3.5 transition-transform group-hover/link:-translate-y-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                      GITHUB
                    </a>
                  )}
                  {p.blog && (
                    <a 
                      href={p.blog} 
                      class="flex items-center gap-2 font-mono text-[0.6875rem] text-muted hover:text-ink transition-colors cursor-none group/link"
                      data-hover
                    >
                      <svg class="w-3.5 h-3.5 transition-transform group-hover/link:-translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                      ARTICLE
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>

          {p.blog && (
            <div class="hidden md:flex flex-col items-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
              <span class="font-mono text-[0.625rem] text-muted uppercase tracking-[0.2em] whitespace-nowrap">{projects.caseStudyLabel}</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
