---
import type { HomeCopy, ProjectItem } from '../../i18n/home';

interface Props {
  sectionId: string;
  projects: HomeCopy['projects'];
  items: ProjectItem[];
  githubUrl: string;
}

const { sectionId, projects, items, githubUrl } = Astro.props;
---

<section id={sectionId} class="border-b border-[var(--border)]">
  <div class="flex flex-col lg:grid lg:grid-cols-[17.5rem_1fr]">
    <div class="p-10 sm:p-14 lg:p-[3.75rem_2.5rem] border-b lg:border-b-0 lg:border-r border-[var(--border)] flex flex-col justify-between">
      <div>
        <div
          class="font-mono text-[0.6875rem] text-muted tracking-[0.12em] uppercase mb-4"
        >
          {projects.sectionNum}
        </div>
        <div
          class="font-display text-[2.75rem] sm:text-[3.25rem] font-extrabold leading-[0.95] tracking-[-0.03em]"
          set:html={projects.sidebarTitleHtml}
        />
        <p class="font-mono text-[0.75rem] text-muted leading-[1.85] mt-5">
          {projects.sidebarLead}
        </p>
      </div>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 block text-center bg-ink text-paper px-5 py-3.5 font-mono text-[0.8125rem] rounded-[0.125rem] no-underline tracking-[0.05em] transition-all duration-200 hover:bg-accent hover:text-ink cursor-none"
        data-hover
      >
        {projects.sidebarCta}
      </a>
    </div>

    <div>
      {items.map((p, i) => (
        <a
          href={p.url}
          class:list={[
            'grid grid-cols-[1fr_auto] items-start gap-5 p-8 sm:px-10 no-underline color-inherit transition-colors duration-150 hover:bg-accent/4 cursor-none group',
            i < items.length - 1 ? 'border-b border-[var(--border)]' : ''
          ]}
          data-hover
        >
          <div>
            <div class="font-mono text-[0.6875rem] text-muted mb-2">{p.num}</div>
            <h3 class="font-display text-[1.5rem] font-bold tracking-[-0.02em] mb-2">
              {p.name}
            </h3>
            <p class="font-mono text-[0.75rem] text-muted leading-[1.75]">{p.desc}</p>
            <div class="flex gap-1.5 flex-wrap mt-3">
              {p.tags.map((tag) => (
                <span
                  class:list={[
                    'font-mono text-[0.625rem] px-2.5 py-1 rounded-[0.125rem] tracking-[0.05em] border transition-colors',
                    p.accentTags.includes(tag) 
                      ? 'border-accent text-accent' 
                      : 'border-[var(--border)] text-muted'
                  ]}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
          <div
            class="arrow text-[1.375rem] text-muted mt-1 transition-all duration-200 group-hover:text-accent group-hover:translate-x-1 group-hover:-translate-y-1"
          >
            ↗
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
