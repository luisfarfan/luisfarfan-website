---
import type { HomeCopy, ProjectItem } from '../../i18n/home';

interface Props {
  sectionId: string;
  projects: HomeCopy['projects'];
  items: ProjectItem[];
  githubUrl: string;
}

const { sectionId, projects, items, githubUrl } = Astro.props;
---

<section id={sectionId} style="border-bottom:1px solid var(--border);">
  <div style="display:grid; grid-template-columns:280px 1fr;">
    <div style="padding:60px 40px; border-right:1px solid var(--border); display:flex; flex-direction:column; justify-content:space-between;">
      <div>
        <div
          style="font-family:'DM Mono',monospace; font-size:11px; color:var(--muted); letter-spacing:.12em; text-transform:uppercase; margin-bottom:16px;"
        >
          {projects.sectionNum}
        </div>
        <div
          style="font-family:'Syne',sans-serif; font-size:52px; font-weight:800; line-height:.95; letter-spacing:-.03em;"
          set:html={projects.sidebarTitleHtml}
        />
        <p style="font-family:'DM Mono',monospace; font-size:12px; color:var(--muted); line-height:1.85; margin-top:20px;">
          {projects.sidebarLead}
        </p>
      </div>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="margin-top:32px; display:block; text-align:center; background:var(--ink); color:var(--paper); padding:14px 20px; font-family:'DM Mono',monospace; font-size:13px; border-radius:2px; text-decoration:none; letter-spacing:.05em; transition:all .2s;"
        onmouseover="this.style.background='var(--accent)'; this.style.color='var(--ink)';"
        onmouseout="this.style.background='var(--ink)'; this.style.color='var(--paper)';"
        data-hover
      >
        {projects.sidebarCta}
      </a>
    </div>

    <div>
      {items.map((p, i) => (
        <a
          href={p.url}
          style={`display:grid; grid-template-columns:1fr auto; align-items:start; gap:20px; padding:32px 40px; ${i < items.length - 1 ? 'border-bottom:1px solid var(--border);' : ''} text-decoration:none; color:inherit; transition:background .15s; group`}
          onmouseover="this.style.background='rgba(0,200,150,0.04)'; this.querySelector('.arrow').style.color='var(--accent)'; this.querySelector('.arrow').style.transform='translate(3px,-3px)';"
          onmouseout="this.style.background='transparent'; this.querySelector('.arrow').style.color='var(--muted)'; this.querySelector('.arrow').style.transform='none';"
          data-hover
        >
          <div>
            <div style="font-family:'DM Mono',monospace; font-size:11px; color:var(--muted); margin-bottom:8px;">{p.num}</div>
            <h3 style="font-family:'Syne',sans-serif; font-size:24px; font-weight:700; letter-spacing:-.02em; margin-bottom:8px;">
              {p.name}
            </h3>
            <p style="font-family:'DM Mono',monospace; font-size:12px; color:var(--muted); line-height:1.75;">{p.desc}</p>
            <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:12px;">
              {p.tags.map((tag) => (
                <span
                  style={`font-family:'DM Mono',monospace; font-size:10px; padding:4px 10px; border-radius:2px; letter-spacing:.05em; border:1px solid ${p.accentTags.includes(tag) ? 'var(--accent)' : 'var(--border)'}; color:${p.accentTags.includes(tag) ? 'var(--accent)' : 'var(--muted)'};`}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
          <div
            class="arrow"
            style="font-size:22px; color:var(--muted); margin-top:4px; transition:color .2s, transform .2s;"
          >
            ↗
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
