---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../Nav.astro';
import SiteFooter from '../SiteFooter.astro';
import type { HomeCopy } from '../../i18n/home';
import { render } from 'astro:content';
import { SITE } from '../../config/site';

interface Props {
  copy: HomeCopy;
  post: any;
}

const { copy, post } = Astro.props;
const { locale, nav, sectionIds, ME, footer, blogList } = copy;
const { Content, headings } = await render(post);

// Calculate canonical and alternates
const slug = post.slug.split('/').pop();
const canonicalUrl = new URL(locale === 'es' ? `/blog/${slug}` : `/en/blog/${slug}`, SITE.url).href;
const hrefEs = new URL(`/blog/${slug}`, SITE.url).href;
const hrefEn = new URL(`/en/blog/${slug}`, SITE.url).href;

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  author: {
    '@type': 'Person',
    name: ME.name,
  },
  datePublished: post.data.date,
  image: SITE.url + '/og-image.png', // Fallback OG image
};
---

<BaseLayout
  lang={locale}
  title={`${post.data.title} | Blog | ${ME.name}`}
  description={post.data.description}
  keywords={copy.meta.keywords}
  canonicalUrl={canonicalUrl}
  openGraphLocale={copy.openGraphLocale}
  personName={ME.name}
  personEmail={ME.email}
  personJobTitle={copy.personJobTitle}
  personDescription={copy.meta.description}
  personSameAs={[ME.github, ME.linkedin, ME.twitter]}
  hreflangAlternates={[
    { hreflang: 'es', href: hrefEs },
    { hreflang: 'en', href: hrefEn },
  ]}
  extraSchema={blogPostSchema}
  articleMeta={{
    publishedTime: post.data.date,
    author: ME.name,
    tags: post.data.tags,
  }}
>
  <Nav locale={locale} nav={nav} sectionIds={sectionIds} me={ME} />

  <main class="min-h-screen border-b border-border bg-grid-pattern">
    <div class="flex flex-col lg:grid lg:grid-cols-[20rem_1fr_18rem]">
      
      <!-- Left Sidebar: Metadata -->
      <aside 
        class="p-10 sm:p-14 lg:p-16 border-b lg:border-b-0 lg:border-r border-border backdrop-blur-xl lg:h-[calc(100vh-4rem)] lg:sticky lg:top-16 z-10 overflow-y-auto"
        style="background-color: color-mix(in srgb, var(--paper) 70%, transparent);"
      >
        <div class="flex flex-col h-full">
          <a 
            href={locale === 'es' ? '/blog' : '/en/blog'} 
            class="font-mono text-[0.625rem] text-accent font-bold uppercase tracking-[0.2em] hover:opacity-70 flex items-center gap-2 mb-12 no-underline cursor-none"
            data-hover
          >
            <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
            {blogList.back}
          </a>

          <div class="space-y-12">
            <div>
              <p class="font-mono text-[0.625rem] text-muted uppercase tracking-widest mb-4">Category</p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags?.map((tag: string) => (
                  <span class="font-mono text-[0.625rem] px-2 py-0.5 border border-border text-ink uppercase tracking-wider">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <div>
          <div class="grid grid-cols-2 lg:grid-cols-1 gap-10">
            <div>
              <p class="font-mono text-[0.5625rem] text-muted uppercase tracking-widest mb-3">Date</p>
              <p class="font-mono text-[0.75rem] text-ink">{new Date(post.data.date).toLocaleDateString(locale, { day: '2-digit', month: 'short', year: 'numeric' })}</p>
            </div>

            <div>
              <p class="font-mono text-[0.5625rem] text-muted uppercase tracking-widest mb-3">Status</p>
              <div class="flex items-center gap-2">
                <span class={`w-1.5 h-1.5 rounded-full ${post.data.status === 'completed' ? 'bg-accent' : 'bg-accent2 animate-pulse'}`}></span>
                <p class="font-mono text-[0.75rem] text-ink uppercase">{post.data.status}</p>
              </div>
            </div>

            {post.data.repositories && (
              <div class="col-span-2 lg:col-span-1">
                <p class="font-mono text-[0.5625rem] text-muted uppercase tracking-widest mb-3">Repositories</p>
                <div class="flex flex-wrap gap-2">
                  {post.data.repositories.map((repo: any) => (
                    <a 
                      href={repo.url} 
                      target="_blank" 
                      rel="noopener noreferrer" 
                      title={repo.name}
                      class="flex items-center justify-center w-8 h-8 border border-border bg-paper/50 hover:border-accent transition-all no-underline cursor-none"
                      data-hover
                    >
                      <svg class="w-3.5 h-3.5 text-muted" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <div class="hidden lg:block mt-auto pt-20">
            <div class="flex items-center gap-3 grayscale hover:grayscale-0 transition-all duration-500">
               <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center font-bold text-ink">LF</div>
               <div>
                  <p class="font-mono text-[0.75rem] font-bold text-ink">{ME.name}</p>
                  <p class="font-mono text-[0.625rem] text-muted uppercase">{blogList.author}</p>
               </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Center: Article Content -->
      <article class="relative min-w-0">
        <header class="p-8 sm:p-20 lg:p-24 border-b border-border">
           <div class="max-w-4xl mx-auto">
              <p class="font-mono text-[0.65rem] sm:text-[0.75rem] text-accent font-bold tracking-[0.3em] uppercase mb-6">
                {blogList.deepDive}
              </p>
              <h1 
                class="font-display text-[2.25rem] sm:text-[3.5rem] lg:text-[4.5rem] font-extrabold leading-[0.95] tracking-[-0.04em] text-ink mb-10"
                transition:name={`blog-title-${post.slug}`}
              >
                {post.data.title}
              </h1>
              <p class="font-mono text-[1rem] sm:text-[1.125rem] text-muted leading-relaxed max-w-2xl">
                {post.data.description}
              </p>
           </div>
        </header>

        <div class="p-8 sm:p-20 lg:p-24 max-w-4xl mx-auto">
          <div class="prose prose-invert prose-ink max-w-none overflow-hidden">
            <Content />
          </div>
        </div>
      </article>

      <!-- Right Sidebar: Fixed Table of Contents -->
      <aside class="hidden xl:block p-16 sticky top-16 h-[calc(100vh-4rem)] border-l border-border overflow-y-auto">
        <div class="space-y-8">
          <div class="relative">
            <p class="font-mono text-[0.625rem] text-muted uppercase tracking-widest mb-10 flex items-center gap-2">
              <span class="w-1 h-1 bg-accent rounded-full"></span>
              Navigation
            </p>
            
            <!-- Vertical Progress Line -->
            <div class="absolute left-[3px] top-14 bottom-0 w-[1px] bg-border/30">
              <div id="toc-progress" class="w-full bg-accent transition-all duration-150 origin-top scale-y-0 h-full"></div>
            </div>

            <nav class="flex flex-col gap-6 pl-6 relative">
              {headings.filter(h => h.depth <= 3).map((heading: any) => (
                <a
                  href={`#${heading.slug}`}
                  data-toc-link={heading.slug}
                  class={`toc-link font-mono text-[0.65rem] leading-snug transition-all duration-300 no-underline hover:text-accent group flex items-start gap-4 ${
                    heading.depth === 2 ? 'text-ink/50' : 'pl-4 text-muted/60'
                  }`}
                  data-hover
                >
                  <span class="toc-number opacity-20 group-hover:opacity-100 transition-opacity font-bold shrink-0">
                    {heading.depth === 2 ? '0' + (headings.filter(h => h.depth === 2).indexOf(heading) + 1) : '—'}
                  </span>
                  <span class="toc-text group-hover:translate-x-1 transition-transform inline-block">
                    {heading.text}
                  </span>
                </a>
              ))}
            </nav>
          </div>

          <div class="pt-12 mt-12 border-t border-border/30">
            <p class="font-mono text-[0.5625rem] text-muted/40 uppercase tracking-widest leading-relaxed">
              Reading time: {Math.ceil(post.body.split(' ').length / 200)} min <br/>
              Last updated: {new Date(post.data.date).toLocaleDateString(locale)}
            </p>
          </div>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* Active TOC state */
  .toc-link.active {
    @apply text-accent font-bold;
  }
  .toc-link.active .toc-number {
    @apply opacity-100;
  }
  .toc-link.active .toc-text {
    @apply translate-x-2;
  }
  .prose h2 {
    @apply font-display text-4xl font-extrabold tracking-tight mt-20 mb-8 text-ink leading-tight;
  }
  .prose h3 {
    @apply font-display text-2xl font-bold tracking-tight mt-12 mb-6 text-accent uppercase;
  }
  .prose p {
    @apply font-mono text-[1.1rem] leading-[1.8] text-muted mb-10;
  }
  .prose strong {
    @apply text-ink font-bold;
  }
  .prose blockquote {
    @apply px-10 py-6 italic rounded-r-xl my-12 border-l-4 border-accent;
    background-color: color-mix(in srgb, var(--accent) 5%, transparent);
  }
  .prose ul {
    @apply list-none p-0 space-y-4 my-10;
  }
  .prose ul li {
    @apply font-mono relative pl-8 text-muted text-[1rem] leading-relaxed;
  }
  .prose ul li::before {
    content: ">>";
    @apply absolute left-0 text-accent font-bold text-[0.8rem] top-0.5;
  }

  .mermaid {
    @apply flex justify-center my-20 p-8 rounded-3xl border backdrop-blur-xl transition-all duration-300;
    border-color: var(--border);
    background-color: color-mix(in srgb, var(--paper) 40%, transparent);
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script is:inline>
  const initBlogScripts = async () => {
    // 1. Initialize Mermaid Diagrams
    const codeBlocks = document.querySelectorAll('pre code');
    codeBlocks.forEach(block => {
      const text = block.textContent.trim();
      if (text.startsWith('graph ') || text.startsWith('flowchart ') || text.startsWith('sequenceDiagram ') || text.startsWith('stateDiagram ') || text.startsWith('classDiagram ')) {
        const pre = block.parentElement;
        const mermaidDiv = document.createElement('div');
        mermaidDiv.className = 'mermaid';
        mermaidDiv.textContent = text;
        pre.parentNode.replaceChild(mermaidDiv, pre);
      }
    });

    if (window.mermaid) {
      window.mermaid.initialize({ startOnLoad: false, theme: 'dark', securityLevel: 'loose' });
      await window.mermaid.run();
    }

    // 2. Initialize Table of Contents
    const tocLinks = document.querySelectorAll('.toc-link');
    const tocProgress = document.getElementById('toc-progress');
    const headings = Array.from(document.querySelectorAll('h2, h3'));

    if (headings.length > 0) {
      const observerOptions = {
        root: null,
        rootMargin: '-10% 0px -80% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach(link => {
              link.classList.toggle('active', link.getAttribute('data-toc-link') === id);
            });
          }
        });
      }, observerOptions);

      headings.forEach(h => {
        if (h.id) observer.observe(h);
      });
    }

    // 3. Progress bar scroll listener
    const updateProgress = () => {
      const winScroll = document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = winScroll / height;
      if (tocProgress) {
        tocProgress.style.transform = `scaleY(${scrolled})`;
      }
    };
    window.addEventListener('scroll', updateProgress);
  };

  document.addEventListener('astro:page-load', initBlogScripts);
</script>
