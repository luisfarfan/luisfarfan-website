---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import type { HomeCopy } from '../../i18n/home';
import { getCollection } from 'astro:content';
import { SITE } from '../../config/site';

interface Props {
  copy: HomeCopy;
}

const { copy } = Astro.props;
const { locale, nav, sectionIds, ME, blogList } = copy;

const posts = await getCollection('blog', ({ id }) => {
  return id.startsWith(`${locale}/`);
});

// Calculate canonical and alternates
const canonicalUrl = new URL(locale === 'es' ? '/blog' : '/en/blog', SITE.url).href;
const hrefEs = new URL('/blog', SITE.url).href;
const hrefEn = new URL('/en/blog', SITE.url).href;
---

<BaseLayout
  lang={copy.htmlLang}
  title={`${blogList.title} | ${ME.name}`}
  description={blogList.description}
  keywords={copy.meta.keywords}
  canonicalUrl={canonicalUrl}
  openGraphLocale={copy.openGraphLocale}
  personName={ME.name}
  personEmail={ME.email}
  personJobTitle={copy.personJobTitle}
  personDescription={copy.meta.description}
  personSameAs={[ME.github, ME.linkedin, ME.twitter]}
  hreflangAlternates={[
    { hreflang: 'es', href: hrefEs },
    { hreflang: 'en', href: hrefEn },
  ]}
>
  <Nav locale={locale} nav={nav} sectionIds={sectionIds} me={ME} />

  <main class="min-h-screen border-b border-[var(--border)] bg-grid-pattern">
    <div class="flex flex-col lg:grid lg:grid-cols-[20rem_1fr]">
      <!-- Sidebar -->
      <aside 
        class="p-10 sm:p-14 lg:p-[5rem_3rem] border-b lg:border-b-0 lg:border-r border-[var(--border)] backdrop-blur-md sticky top-14 lg:top-16 lg:h-[calc(100vh-4rem)] flex flex-col justify-between z-10"
        style="background-color: color-mix(in srgb, var(--paper) 80%, transparent)"
      >
        <div>
          <div class="font-mono text-[0.6875rem] text-accent tracking-[0.15em] uppercase mb-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            {locale === 'es' ? 'Bitácora' : 'Journal'}
          </div>
          <h1 class="font-display text-[clamp(2.25rem,5vw,3.5rem)] font-extrabold leading-[0.9] tracking-[-0.04em] text-ink break-words">
            {blogList.title.split(' ').map((word: string, i: number) => (
              <span class={word.toLowerCase() === 'ingeniería' || word.toLowerCase() === 'journal' ? 'text-accent' : ''}>{word}<br/></span>
            ))}
          </h1>
          <p class="font-mono text-[0.8125rem] text-muted leading-[1.8] mt-8 max-w-[15rem]">
            {blogList.description}
          </p>
        </div>

        <div class="mt-12 lg:mt-0">
          <p class="font-mono text-[0.625rem] text-muted uppercase tracking-widest mb-4">Total entries</p>
          <div class="text-4xl font-display font-bold text-ink">
            {posts.length.toString().padStart(2, '0')}
          </div>
        </div>
      </aside>

      <!-- Content -->
      <div 
        class="divide-y divide-[var(--border)]"
        style="background-color: color-mix(in srgb, var(--paper) 40%, transparent)"
      >
        {posts.length > 0 ? (
          posts.map((post, i) => (
            <a
              href={locale === 'es' ? `/blog/${post.slug.split('/').pop()}` : `/en/blog/${post.slug.split('/').pop()}`}
              class="group relative block p-10 sm:p-16 lg:p-20 overflow-hidden transition-all duration-300 no-underline cursor-none"
              style="--hover-bg-glass: color-mix(in srgb, var(--paper) 80%, transparent); --hover-accent-glow: color-mix(in srgb, var(--accent) 2%, transparent);"
              onmouseover="this.style.backgroundColor=this.style.getPropertyValue('--hover-bg-glass')"
              onmouseout="this.style.backgroundColor='transparent'"
              data-hover
            >
              {/* Animated glass background */}
              <div 
                class="absolute inset-0 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out" 
                style="background-color: var(--hover-accent-glow)"
              />
              
              <div class="relative z-10 flex flex-col md:flex-row md:items-start md:justify-between gap-8">
                <div class="flex-1">
                  <div class="flex items-center gap-4 mb-6">
                    <span class="font-mono text-[0.625rem] text-accent font-bold tracking-[0.2em] uppercase">
                      Entry #{(i + 1).toString().padStart(3, '0')}
                    </span>
                    <span class="h-px w-8 bg-border" />
                    <span class="font-mono text-[0.625rem] text-muted uppercase tracking-widest">
                      {post.data.tags?.[0] || 'Technical'}
                    </span>
                    <span class="ml-auto flex items-center gap-2">
                      <span class={`font-mono text-[0.55rem] px-1.5 py-0.5 border uppercase tracking-wider rounded-[2px] ${
                        post.data.status === 'completed' ? 'border-green-500/30 text-green-500/80 bg-green-500/5' :
                        post.data.status === 'stopped' ? 'border-red-500/30 text-red-500/80 bg-red-500/5' :
                        post.data.status === 'in-progress' ? 'border-accent/30 text-accent/80 bg-accent/5' :
                        'border-muted/30 text-muted/80 bg-muted/5'
                      }`}>
                        {post.data.status.replace('-', ' ')}
                      </span>
                      {post.data.status === 'in-progress' && (
                        <span class="font-mono text-[0.55rem] text-muted/60">{post.data.progress}%</span>
                      )}
                    </span>
                  </div>

                  <h2 class="font-display text-[2.25rem] sm:text-[3rem] font-bold tracking-tight text-ink group-hover:text-accent transition-colors duration-300 leading-[1.1] mb-6">
                    {post.data.title}
                  </h2>

                  <p class="font-mono text-[0.875rem] text-muted leading-relaxed max-w-2xl group-hover:text-ink transition-colors duration-300">
                    {post.data.description}
                  </p>

                  <div class="flex flex-wrap gap-2 mt-8">
                    {post.data.tags?.map((tag: string) => (
                      <span 
                        class="font-mono text-[0.625rem] px-2.5 py-1 rounded-[0.125rem] border text-muted transition-colors group-hover:text-accent"
                        style="border-color: var(--border); --hover-border: color-mix(in srgb, var(--accent) 30%, transparent); --hover-bg: color-mix(in srgb, var(--accent) 5%, transparent);"
                        onmouseover="this.style.borderColor=this.style.getPropertyValue('--hover-border'); this.style.backgroundColor=this.style.getPropertyValue('--hover-bg')"
                        onmouseout="this.style.borderColor='var(--border)'; this.style.backgroundColor='transparent'"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="flex items-center gap-4 text-ink self-end md:self-start group-hover:translate-x-2 transition-transform duration-300">
                  <span class="font-mono text-[0.75rem] font-bold uppercase tracking-[0.15em]">
                    {locale === 'es' ? 'Leer ahora' : 'Read more'}
                  </span>
                  <svg class="w-6 h-6 stroke-accent" fill="none" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
                  </svg>
                </div>
              </div>
            </a>
          ))
        ) : (
          <div class="p-20 text-center font-mono text-muted">
             {locale === 'es' ? 'No hay publicaciones aún.' : 'No posts found yet.'}
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer footer={copy.footer} me={ME} />
</BaseLayout>

<style>
  .bg-grid-pattern {
    background-image: 
      linear-gradient(var(--bento-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--bento-border) 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>
