---
import { getCollection } from 'astro:content';
import BlogPostPage from '../../../components/pages/BlogPostPage.astro';
import { homeEn } from '../../../i18n/home';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ id }) => id.startsWith('en/'));
  return blogEntries.map(entry => ({
    params: { slug: entry.slug.split('/').pop() }, props: { entry },
  }));
}

const { entry } = Astro.props;
---

<BlogPostPage copy={homeEn} post={entry} />
